menu "Network Configuration"
    config NETWORK_ENABLE
        bool "Enable Network component"
        default y
        help
            Enable WiFi provisioning and network test features.

    config NETWORK_DEFAULT_HOST
        string "Default ping/test host"
        default "baidu.com"
        help
            Default hostname for ping and connectivity tests.

    config NETWORK_PROV_AP_SSID
        string "Provisioning AP SSID"
        default "box-demo-config"
        help
            SSID of the SoftAP created for WiFi provisioning.

    config NETWORK_MAX_RESULT_LINES
        int "Max result text lines"
        default 80
        range 20 200
        help
            Maximum number of result text lines to buffer for scrollback.
endmenu
