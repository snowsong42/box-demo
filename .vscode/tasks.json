{
  "version": "2.0.0",
  "windows": {
    "options": {
      "shell": {
        "executable": "cmd.exe",
        "args": ["/d", "/c"]
      },
      "env": {
        "IDF_PATH": "D:\\EE\\ESP-IDF\\.espressif\\v6.0.1\\esp-idf",
        "IDF_TOOLS_PATH": "C:\\Users\\snowsong\\.espressif\\tools",
        "IDF_PYTHON_ENV_PATH": "C:\\Espressif\\tools\\python\\v6.0.1\\venv",
        "ESP_IDF_VERSION": "6.0.1",
        "PATH": "C:\\Users\\snowsong\\.espressif\\tools\\cmake\\4.0.3\\bin;C:\\Users\\snowsong\\.espressif\\tools\\ninja\\1.12.1;C:\\Espressif\\tools\\python\\v6.0.1\\venv\\Scripts;C:\\Users\\snowsong\\.espressif\\tools\\idf-exe\\1.0.3;${env:PATH}"
      }
    }
  },
  "tasks": [
    {
      "label": "ESP-IDF: Build",
      "type": "shell",
      "command": "C:\\Users\\snowsong\\.espressif\\tools\\idf-exe\\1.0.3\\idf.py.exe build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.+):(\\d+):\\d+:\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    },
    {
      "label": "ESP-IDF: Clean",
      "type": "shell",
      "command": "C:\\Users\\snowsong\\.espressif\\tools\\idf-exe\\1.0.3\\idf.py.exe fullclean",
      "group": "build"
    },
    {
      "label": "ESP-IDF: Flash",
      "type": "shell",
      "command": "C:\\Users\\snowsong\\.espressif\\tools\\idf-exe\\1.0.3\\idf.py.exe flash",
      "group": "none",
      "dependsOn": ["ESP-IDF: Build"]
    },
    {
      "label": "ESP-IDF: Monitor",
      "type": "shell",
      "command": "C:\\Users\\snowsong\\.espressif\\tools\\idf-exe\\1.0.3\\idf.py.exe monitor",
      "group": "none",
      "isBackground": false
    },
    {
      "label": "ESP-IDF: Build, Flash & Monitor",
      "type": "shell",
      "command": "C:\\Users\\snowsong\\.espressif\\tools\\idf-exe\\1.0.3\\idf.py.exe build flash monitor",
      "group": "none",
      "isBackground": false
    }
  ]
}
