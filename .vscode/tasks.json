{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESP-IDF: Build",
      "type": "shell",
      "command": "idf.py build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.+):(\\d+):\\d+:\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    },
    {
      "label": "ESP-IDF: Clean",
      "type": "shell",
      "command": "idf.py fullclean",
      "group": "build"
    },
    {
      "label": "ESP-IDF: Flash",
      "type": "shell",
      "command": "idf.py flash",
      "group": "none",
      "dependsOn": ["ESP-IDF: Build"]
    },
    {
      "label": "ESP-IDF: Monitor",
      "type": "shell",
      "command": "idf.py monitor",
      "group": "none",
      "isBackground": false
    },
    {
      "label": "ESP-IDF: Build, Flash & Monitor",
      "type": "shell",
      "command": "idf.py build flash monitor",
      "group": "none",
      "isBackground": false
    }
  ]
}
